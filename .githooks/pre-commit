#!/bin/sh
# Pre-commit hook: Require a CHANGELOG-*.md file in every commit
#
# Checks that at least one CHANGELOG-*.md file is being committed
# alongside code changes.

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

# Skip check if no files staged
if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# Check if only non-code files are being committed (allow docs-only commits)
CODE_FILES=$(echo "$STAGED_FILES" | grep -vE '\.(md|txt|json)$' | grep -vE '^\.agent/')
if [ -z "$CODE_FILES" ]; then
    exit 0
fi

# Check if any CHANGELOG file is staged in changelogs/ directory
CHANGELOG_FILE=$(echo "$STAGED_FILES" | grep -E '^changelogs/CHANGELOG-.*\.md$')

if [ -z "$CHANGELOG_FILE" ]; then
    echo ""
    echo "❌ COMMIT BLOCKED: No changelog found in changelogs/ directory."
    echo ""
    echo "Every commit with code changes must include a changelogs/CHANGELOG-<topic>.md file."
    echo ""
    echo "Example:"
    echo "  mkdir -p changelogs"
    echo "  echo '# Changes\\n- Fixed bug X' > changelogs/CHANGELOG-bugfix.md"
    echo "  git add changelogs/CHANGELOG-bugfix.md"
    echo ""
    exit 1
fi

exit 0
