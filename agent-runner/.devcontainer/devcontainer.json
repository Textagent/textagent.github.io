{
  "name": "TextAgent Runner",
  "image": "mcr.microsoft.com/devcontainers/python:3.12-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "20" },
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "postCreateCommand": "bash /workspaces/agent-runner/scripts/setup.sh",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": { "label": "Exec API", "onAutoForward": "silent", "visibility": "public" }
  },
  "customizations": {
    "codespaces": {
      "openFiles": ["README.md"]
    }
  }
}
